model RentalOrder {

    id String @id @default(uuid()) @db.Uuid

    customerId String @db.Uuid
    customer User @relation("CustomerOrders", fields: [customerId], references: [id])

    providerId String @db.Uuid
    provider User @relation("ProviderOrders", fields: [providerId], references: [id])

    orderNumber String @unique @db.VarChar(50)

    subtotal Decimal @db.Decimal(10,2)

    discount Decimal @default(0) @db.Decimal(10,2)

    tax Decimal @default(0) @db.Decimal(10,2)

    securityDeposit Decimal @default(0) @db.Decimal(10,2)

    total Decimal @db.Decimal(10,2)

    rentalStartDate DateTime
    rentalEndDate DateTime

    status RentalStatus @default(PLACED)

    paymentStatus PaymentStatus @default(PENDING)

    notes String?

    items RentalOrderItem[]

    payments Payment[]

    review Review?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([customerId])
    @@index([providerId])
    @@map("rental_orders")
}




model RentalOrderItem {

    id String @id @default(uuid()) @db.Uuid

    orderId String @db.Uuid
    order RentalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

    gearId String @db.Uuid
    gear GearItem @relation(fields: [gearId], references: [id])

    quantity Int

    dailyPrice Decimal @db.Decimal(10,2)

    days Int

    securityDeposit Decimal @db.Decimal(10,2)

    subtotal Decimal @db.Decimal(10,2)

    createdAt DateTime @default(now())

    @@map("rental_order_items")
}
