model Review {

  id String @id @default(uuid()) @db.Uuid

  gearId String @db.Uuid
  gear GearItem @relation(fields: [gearId], references: [id])

  customerId String @db.Uuid
  customer User @relation(fields: [customerId], references: [id])

  orderId String @unique @db.Uuid
  order RentalOrder @relation(fields: [orderId], references: [id])

  rating Int

  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gearId, customerId])
  @@map("reviews")
}



model ReviewImage {
  id String @id @default(uuid()) @db.Uuid

  gearId String @db.Uuid
  gear   GearItem @relation(fields: [gearId], references: [id], onDelete: Cascade)

  imageUrl String

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("gear_images")
}