model Category {
    id          String @id @default(uuid()) @db.Uuid

    name        String @db.VarChar(100)
    slug        String @unique @db.VarChar(120)

    description String?
    icon        String?

    isActive    Boolean @default(true)

    gearItems   GearItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("categories")
}